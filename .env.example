# Copy this file to .env and fill in your real secrets.
# Current code reads environment variables directly.
# Before starting the app, run: set -a; source .env; set +a

# OpenAI-compatible provider example (Novita)
OPENAI_API_KEY=your_openai_compatible_api_key_here
OPENAI_BASE_URL=https://api.novita.ai/v3/openai
OPENAI_MODEL=pa/claude-opus-4-6

# Anthropic example
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
